// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum UserRole {
  STUDENT
  TUTOR
  ADMIN
}

// USER & PROFILE MANAGEMENT

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  emailVerified Boolean  @default(false)
  role          UserRole @default(STUDENT)

  profile              UserProfile?
  forumPosts           ForumPost[]
  forumReplies         ForumReply[]
  chatMessagesSent     ChatMessage[]      @relation("sender")
  chatMessagesReceived ChatMessage[]      @relation("recipient")
  chatSessions         ChatSession[]
  studyMaterials       StudyMaterial[]
  studyGroupsOwned     StudyGroup[]       @relation("owner")
  studyGroupMembers    StudyGroupMember[]
  upvotedForumPosts    ForumPost[]        @relation("upvoters")
  upvotedReplies       ForumReply[]       @relation("upvoters")
  sessions             Session[]
  accounts             Account[]
  events               Event[]
  flaggedContents      FlaggedContent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?
  bio         String?
  avatarUrl   String?
  university  String?
  major       String?
  reputation  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([reputation])
}

// BETTER AUTH TABLES
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// FORUM & DISCUSSIONS

model ForumPost {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title        String
  content      String
  category     String
  upvotes      Int     @default(0)
  views        Int     @default(0)
  isAnswered   Boolean @default(false)
  repliesCount Int     @default(0)

  replies  ForumReply[]
  tags     ForumTag[]
  upvoters User[]     @relation("upvoters")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@index([upvotes])
  @@index([isAnswered])
}

model ForumReply {
  id     String    @id @default(cuid())
  postId String
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  content    String
  upvotes    Int     @default(0)
  isAccepted Boolean @default(false)
  upvoters   User[]  @relation("upvoters")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@index([upvotes])
  @@index([isAccepted])
}

model ForumTag {
  id   String @id @default(cuid())
  name String @unique

  posts ForumPost[]

  createdAt DateTime @default(now())
}

// CHAT & MESSAGING

model ChatMessage {
  id          String       @id @default(cuid())
  senderId    String
  sender      User         @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User         @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  sessionId   String?
  session     ChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  content     String
  role        String  @default("user")
  messageType String  @default("text")
  isRead      Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([recipientId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([isRead])
}

model ChatSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String  @default("Chat Session")
  subject     String  @default("General")
  description String?
  messages    ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

// STUDY MATERIALS

model StudyMaterial {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  fileUrl     String
  subject     String
  fileType    String?
  downloads   Int   @default(0)
  rating      Float @default(0)
  reviewCount Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([subject])
  @@index([createdAt])
  @@index([rating])
}

// STUDY GROUPS

model StudyGroup {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation("owner", fields: [ownerId], references: [id], onDelete: Cascade)

  name        String
  description String?
  subject     String
  maxMembers  Int?
  isPrivate   Boolean @default(false)
  inviteCode  String?
  memberCount Int     @default(1)

  members StudyGroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([subject])
  @@index([createdAt])
  @@index([isPrivate])
}

model StudyGroupMember {
  id      String     @id @default(cuid())
  groupId String
  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  role     String   @default("member")
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model FlaggedContent {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  contentType String
  contentId   String
  reason      String
  status      String   @default("pending")
  resolvedBy  String?
  resolution  String?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@index([reporterId])
  @@index([contentType, contentId])
  @@index([status])
  @@index([createdAt])
}

model Event {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  date        DateTime
  startTime   String?
  endTime     String?
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([createdAt])
}


